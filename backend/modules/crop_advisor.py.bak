        "seasonal_plan": "మీ క్షేత్రాన్ని బాగా సిద్ధం చేయండి. విత్తన చికిత్స నిశ్చితం చేయండి.",
        "fertilizer_schedule": "విత్తన సమయంలో ఆధార సారం వర్తించండి. పెరుగుతున్న సీజన్‌లో విభజిత కొవ్వులను వర్తించండి.",
        "pest_watch": "సాధారణ తెగుళ్ల మరియు వ్యాధుల కోసం క్రమం తప్పకుండా పర్యవేక్షణ చేయండి.",
        "harvest_window": "ఫసల్ పూర్తి పరిపక్వతకు చేరుకున్నప్పుడు కోయండి.",
        "tips": "సరైన నీటిపానం నిర్వహించండి, నియమిత ఆధారంపై కలుపులను తీసివేయండి."
    }
}


def _extract_json_from_response(response: str) -> dict:
    """Extract JSON from response, handling potential formatting issues."""
    print("=" * 80)
    print("RAW LLM RESPONSE:")
    print(response)
    print("=" * 80)
    
    # Try to find JSON in the response
    json_match = re.search(r'\{.*\}', response, re.DOTALL)
    
    if json_match:
        json_str = json_match.group(0)
        try:
            return json.loads(json_str)
        except json.JSONDecodeError:
            # Try to repair common JSON issues
            print("🔧 Attempting to repair malformed JSON...")
            json_str = json_str.replace("'", '"')  # Single to double quotes
            json_str = re.sub(r',\s*}', '}', json_str)  # Remove trailing commas
            json_str = re.sub(r',\s*]', ']', json_str)  # Remove trailing commas in arrays
            try:
                return json.loads(json_str)
            except json.JSONDecodeError as e:
                print(f"❌ Failed to repair JSON: {e}")
                return None
    
    return None


def _generate_response_from_knowledge_base(crop: str, district: str, state: str, sowing_date: str, lang: str) -> dict:
    """Generate response directly from knowledge base to guarantee crop-specific answers."""
    crop_info = _get_crop_knowledge(crop, lang)
    
    if not crop_info:
        return None
    
    print(f"✅ Generating response from knowledge base for {crop} in {lang}")
    
    # Calculate harvest date
    try:
        maturity = crop_info.get("maturity_days", "90-120")
        # Extract first number from range like "120-150"
        if "-" in str(maturity):
            days = int(str(maturity).split("-")[0])
        else:
            days = int("".join(filter(str.isdigit, str(maturity))))
    except:
        days = 120
    
    # Generate templated response with crop-specific data
    if lang == "hi":
        seasonal = f"खेत की तैयारी:\n{crop} के लिए मिट्टी को अच्छी तरह तैयार करें। बुवाई की गहराई: {crop_info.get('planting_depth', '3-4 सेमी')}। पंक्ति की दूरी: {crop_info.get('spacing', '20-23 सेमी')}। {district}, {state} में बुवाई {sowing_date} को करें।"
        
        fertilizer = f"उर्वरक योजना:\nNPK अनुपात {crop_info.get('npk_ratio', '120:60:40')} का उपयोग करें।\nआवेदन समय: {crop_info.get('fertilizer_timing', 'बुवाई पर, 4-6 सप्ताह, 8-10 सप्ताह')}"
        
        pests = f"कीट और रोग नियंत्रण:\nकीट: {crop_info.get('common_pests', 'विभिन्न कीट')}\nरोग: {crop_info.get('common_diseases', 'विभिन्न रोग')}\nनियमित निरीक्षण और समय पर कीटनाशक उपचार आवश्यक है।"
        
        harvest = f"कटाई का समय:\nपरिपक्वता अवधि: {crop_info.get('maturity_days', '120-150 दिन')}\n{sowing_date} से लगभग {days} दिन बाद कटाई के लिए तैयार होगी।"
        
        tips = f"महत्वपूर्ण सुझाव:\nसिंचाई: {crop_info.get('irrigation', 'आवश्यकतानुसार')}\nसमय पर निराई-गुड़ाई करें और कटाई के बाद उचित भंडारण सुनिश्चित करें।"
    
    elif lang == "te":
        seasonal = f"క్షేత్ర సిద్ధీకరణ:\n{crop} కోసం మట్టిని బాగా సిద్ధం చేయండి. విత్తన లోతు: {crop_info.get('planting_depth', '3-4 సెం.మీ')}. వరుస దూరం: {crop_info.get('spacing', '20-23 సెం.మీ')}. {district}, {state} లో {sowing_date} న విత్తన చేయండి."
        
        fertilizer = f"సారం షెడ్యూల్:\nNPK నిష్పత్తి {crop_info.get('npk_ratio', '120:60:40')} ఉపయోగించండి.\nఅనువర్తన సమయం: {crop_info.get('fertilizer_timing', 'విత్తన సమయంలో, 4-6 వారాలలో, 8-10 వారాలలో')}"
        
        pests = f"కీటకాలు మరియు వ్యాధుల నియంత్రణ:\nకీటకాలు: {crop_info.get('common_pests', 'వివిధ కీటకాలు')}\nవ్యాధులు: {crop_info.get('common_diseases', 'వివిధ వ్యాధులు')}\nక్రమం తప్పకుండా పర్యవేక్షణ మరియు సమయ కీటకనాశకం చికిత్స అవసరం."
        
        harvest = f"కోత సమయం:\nపరిపక్వత కాలం: {crop_info.get('maturity_days', '120-150 రోజులు')}\n{sowing_date} నుండి సుమారు {days} రోజుల తర్వాత కోయటానికి సిద్ధమవుతుంది."
        
        tips = f"ముఖ్యమైన చిట్కాలు:\nనీటిపాన: {crop_info.get('irrigation', 'అవసరమైన విధంగా')}\nసమయానికి సాలెపు చేయండి మరియు కోత తర్వాత సరైన నిల్వ నిర్ధారించండి."
        
        harvest = f"{crop} కోసం కోత కాలం: పరిపక్వత కాలం {crop_info.get('maturity_days', '120-150 రోజులు')} ఉంది. {sowing_date} నుండి సుమారు {days} రోజుల తర్వాత కోయటానికి సిద్ధమవుతుంది."
        
        tips = f"{crop} కోసం చిట్కాలు: నీటిపాన {crop_info.get('irrigation', 'అవసరమైన విధంగా')}. {crop} విజయవంతమైన సాగు కోసం సময়సమర్థమైన నిర్వహణ ఆవశ్యక."
    
    else:  # English or default
        seasonal = f"Field preparation:\nPrepare soil thoroughly for {crop}. Planting depth: {crop_info.get('planting_depth', '3-4 cm')}. Row spacing: {crop_info.get('spacing', '20-23 cm')}. Sow on {sowing_date} in {district}, {state}."
        
        fertilizer = f"Fertilizer schedule:\nApply NPK ratio of {crop_info.get('npk_ratio', '120:60:40')}.\nApplication timing: {crop_info.get('fertilizer_timing', 'At sowing, 4-6 weeks, 8-10 weeks')}"
        
        pests = f"Pest and disease management:\nPests: {crop_info.get('common_pests', 'various pests')}\nDiseases: {crop_info.get('common_diseases', 'various diseases')}\nRegular monitoring and timely pesticide treatment required."
        
        harvest = f"Harvest window:\nMaturity period: {crop_info.get('maturity_days', '120-150 days')}\nApproximately {days} days after sowing on {sowing_date}, your {crop} will be ready for harvest."
        
        tips = f"Important tips:\nIrrigation: {crop_info.get('irrigation', 'as needed')}\nPerform timely weeding and ensure proper storage after harvest."
    
    return {
        "seasonal_plan": seasonal,
        "fertilizer_schedule": fertilizer,
        "pest_watch": pests,
        "harvest_window": harvest,
        "tips": tips
    }


def _is_response_crop_specific(response_dict: dict, crop: str) -> bool:
    """Validate that response is specific to the crop, not generic."""
    crop_lower = crop.lower().split('/')[0]
    
    # Count how many fields contain crop-specific keywords
    specific_count = 0
    for field, content in response_dict.items():
        if isinstance(content, str) and content:
            # Check for crop-specific content
            if (crop_lower in content.lower() or 
                "this crop" in content.lower() or
                "specific" in content.lower() or
                len(content) > 100):  # Substantial content
                specific_count += 1
    
    # At least 3 fields should be crop-specific
    return specific_count >= 3



def get_crop_advice(
    crop: str,
    district: str,
    state: str,
    sowing_date: str,
    lang: str = "en",
    settings: dict = None
) -> dict:
    """
    Get comprehensive crop advice from AI based on crop type, location, and sowing date.
    
    Args:
        crop: Name of the crop (e.g., "Wheat/गेहूं")
        district: District name
        state: State name
        sowing_date: Date of sowing (YYYY-MM-DD format)
        lang: Language code ("en", "hi", or "te")
        settings: AI provider settings dictionary
    
    Returns:
        dict: Contains seasonal_plan, fertilizer_schedule, pest_watch, harvest_window, tips
              Always returns all 5 fields with content (never empty)
              Returns error dict on failure
    """
    if settings is None:
        settings = {"provider": "ollama", "model": "llama3"}
    
    if lang not in SUPPORTED_LANGUAGES:
        lang = "en"
    
    try:
        # Debug: Print received parameters
        print("\n" + "=" * 80)
        print("🚀 RECEIVED PARAMETERS:")
        print(f"   Crop: {crop}")
        print(f"   District: {district}")
        print(f"   State: {state}")
        print(f"   Sowing Date: {sowing_date}")
        print(f"   Language: {lang}")
        print("=" * 80)
        # Create unique identifier to prevent caching
        unique_id = hashlib.md5(f"{crop}{district}{state}{sowing_date}".encode()).hexdigest()[:8]
        timestamp = datetime.now().isoformat()
        
        # Get crop-specific knowledge
        crop_info = _get_crop_knowledge(crop, lang)
        
        # Build crop-specific data section
        crop_data_section = ""
        if crop_info:
            crop_data_section = f"""
CROP-SPECIFIC DATA FOR {crop.upper()}:
- Maturity Period: {crop_info.get('maturity_days', 'N/A')} days
- Common Pests: {crop_info.get('common_pests', 'N/A')}
- Common Diseases: {crop_info.get('common_diseases', 'N/A')}
- NPK Ratio: {crop_info.get('npk_ratio', 'N/A')}
- Fertilizer Schedule: {crop_info.get('fertilizer_timing', 'N/A')}
- Irrigation Needs: {crop_info.get('irrigation', 'N/A')}
- Seed Rate: {crop_info.get('seed_rate', 'N/A')}
- Planting Depth: {crop_info.get('planting_depth', 'N/A')}
- Row Spacing: {crop_info.get('spacing', 'N/A')}
"""
        
        # Construct the user prompt with crop-specific data
        prompt = f"""[REQUEST_ID: {unique_id} at {timestamp}]

⚠️ CRITICAL: Provide advice for {crop.upper()} ONLY.
{crop_data_section}

The farmer is growing: {crop}
District: {district}
State: {state}
Sowing Date: {sowing_date}

YOUR TASK: Give agricultural advice SPECIFIC to {crop} using the data provided above.

INSTRUCTIONS:
1. Do NOT give generic advice
2. Do NOT copy responses from other crops
3. Use the crop-specific data provided above
4. Reference specific pests, diseases, NPK values, irrigation, and maturity from the data
5. Calculate harvest date from {sowing_date} + maturity days for {crop}
6. Every field must mention {crop} specifically

seasonal_plan: 
What should a farmer growing {crop} do?
- Use planting depth: {crop_info.get('planting_depth', 'standard')}
- Use spacing: {crop_info.get('spacing', 'standard')}
- Specific soil preparation for {crop}

fertilizer_schedule: 
What does {crop} need?
- Use NPK ratio: {crop_info.get('npk_ratio', 'N/A')}
- Use schedule: {crop_info.get('fertilizer_timing', 'N/A')}
- Specific application for {crop}

pest_watch: 
What attacks {crop}?
- Pests: {crop_info.get('common_pests', 'check reference sources')}
- Diseases: {crop_info.get('common_diseases', 'check reference sources')}
- Unique to {crop}

harvest_window: 
When to harvest {crop}?
- Maturity: {crop_info.get('maturity_days', '90-120')} days
- Harvest around: {sowing_date} + {crop_info.get('maturity_days', 'X')} days
- Indicators for {crop}

tips: 
How to grow {crop} successfully?
- Irrigation: {crop_info.get('irrigation', 'standard')}
- Specific to {crop}

RESPOND WITH ONLY VALID JSON - NO OTHER TEXT - NO BRACKETS:
{{
  "seasonal_plan": "Field preparation for {crop}: {crop_info.get('planting_depth', 'standard depth')}, spacing {crop_info.get('spacing', 'standard spacing')}. Sow {crop} on {sowing_date} in {district}.",
  "fertilizer_schedule": "{crop} requires NPK {crop_info.get('npk_ratio', 'standard ratio')} applied at {crop_info.get('fertilizer_timing', 'standard timing')}.",
  "pest_watch": "{crop} commonly faces {crop_info.get('common_pests', 'standard pests')} and {crop_info.get('common_diseases', 'standard diseases')}. Monitor regularly.",
  "harvest_window": "{crop} matures in {crop_info.get('maturity_days', 'X')} days. Harvest around {sowing_date}.",
  "tips": "{crop} needs {crop_info.get('irrigation', 'regular irrigation')}. Maintain weed-free field and monitor health."
}}"""
        
        system_prompt = SYSTEM_PROMPTS.get(lang, SYSTEM_PROMPTS["en"])
        
        print("=" * 80)
        print(f"📝 PROMPT SENT TO MODEL [ID: {unique_id}]:")
        print(f"🌾 CROP: {crop} | DISTRICT: {district} | STATE: {state} | SOWING: {sowing_date}")
        print(prompt)
        print("=" * 80)
        
        response = get_response(prompt, system_prompt, settings)
        
        # Check if response is an error message
        if response.startswith("Error:"):
            print(f"⚠️  LLM Error: {response}")
            return {"error": response}
        
        # Extract and parse JSON
        parsed_json = _extract_json_from_response(response)
        
        if parsed_json:
            print("=" * 80)
            print("✅ PARSED JSON:")
            print(json.dumps(parsed_json, indent=2, ensure_ascii=False))
            print("=" * 80)
            
            # Validate crop specificity
            is_specific = _is_response_crop_specific(parsed_json, crop)
            
            if not is_specific:
                print(f"⚠️  Response is not crop-specific for {crop}")
                print("   Falling back to knowledge base response...")
                kb_response = _generate_response_from_knowledge_base(crop, district, state, sowing_date, lang)
                if kb_response:
                    return kb_response
            else:
                print(f"✅ Response is specific to {crop}")
            
            # Validate all required fields are present
            result = {
                "seasonal_plan": parsed_json.get("seasonal_plan", "").strip(),
                "fertilizer_schedule": parsed_json.get("fertilizer_schedule", "").strip(),
                "pest_watch": parsed_json.get("pest_watch", "").strip(),
                "harvest_window": parsed_json.get("harvest_window", "").strip(),
                "tips": parsed_json.get("tips", "").strip()
            }
            
            # Add fallback values for any empty fields
            fallbacks = FALLBACK_RESPONSES.get(lang, FALLBACK_RESPONSES["en"])
            for key in result:
                if not result[key] or len(result[key]) < 5:
                    print(f"⚠️  Field '{key}' was empty/insufficient, using fallback")
                    result[key] = fallbacks[key]
            
            return result
        else:
            # JSON parsing failed, use knowledge base to generate response
            print("❌ Failed to parse JSON from response")
            print("   Generating response from knowledge base...")
            kb_response = _generate_response_from_knowledge_base(crop, district, state, sowing_date, lang)
            if kb_response:
                return kb_response
            
            # Last resort: use pre-written fallback values
            print("⚠️  Using pre-written fallback values")
            return FALLBACK_RESPONSES.get(lang, FALLBACK_RESPONSES["en"])
        
    except Exception as e:
        print(f"❌ Exception in get_crop_advice: {str(e)}")
        import traceback
        traceback.print_exc()
        return {"error": f"Failed to get crop advice: {str(e)}"}
