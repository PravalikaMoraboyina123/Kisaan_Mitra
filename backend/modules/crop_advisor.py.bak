def _get_crop_knowledge(crop: str, lang: str) -> dict:
    """Get crop-specific knowledge from the database."""
    # Extract crop name without translation
    crop_name = crop.split('/')[0] if '/' in crop else crop
    
    # Try exact match first
    if crop in CROP_KNOWLEDGE_BASE:
        return CROP_KNOWLEDGE_BASE[crop].get(lang, {})
    
    # Try partial match
    for key in CROP_KNOWLEDGE_BASE:
        if crop_name.lower() in key.lower():
            return CROP_KNOWLEDGE_BASE[key].get(lang, {})
    
    return {}
