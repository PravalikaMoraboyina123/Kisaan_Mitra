        }
        
        .message.user .message-bubble {
            background: #4CAF50;
            color: white;
            border-radius: 12px 12px 0 12px;
        }
        
        .message.assistant .message-bubble {
            background: #e8f5e9;
            color: #333;
            border-radius: 12px 12px 12px 0;
        }
        
        .chat-welcome {
            padding: 2rem;
            text-align: center;
            color: #666;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100%;
        }
        
        .chat-welcome-emoji {
            font-size: 3rem;
            margin: 1rem 0;
        }
        
        .chat-welcome-title {
            font-size: 1.1rem;
            margin: 0.5rem 0;
            font-weight: 600;
        }
        
        .chat-welcome-text {
            font-size: 0.85rem;
            margin: 0.3rem 0;
        }
        
        /* Chat Input Section - INSIDE the panel */
        .chat-input-section {
            padding: 1rem;
            background: white;
            border-top: 1px solid #e0e0e0;
            display: flex;
            gap: 0.5rem;
        }
        
        .chat-input-section input {
            flex: 1;
            padding: 0.75rem;
            border: 1px solid #d0d0d0;
            border-radius: 20px;
            font-size: 0.9rem;
            font-family: inherit;
        }
        
        .chat-input-section input:focus {
            outline: none;
            border-color: #4CAF50;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.1);
        }
        
        .chat-input-section button {
            padding: 0.75rem 1rem;
            background: #4CAF50;
            color: white;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .chat-input-section button:hover {
            background: #45a049;
        }
        
        .chat-input-section button:active {
            transform: scale(0.95);
        }
        
        /* Scrollbar */
        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }
        
        .chat-messages::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        
        .chat-messages::-webkit-scrollbar-thumb {
            background: #4CAF50;
            border-radius: 3px;
        }
    </style>
    """
    
    st.markdown(floating_css, unsafe_allow_html=True)
    
    # Create pure HTML floating action button with onclick handler
    fab_html = """
    <button class="fab-button" id="fab-button" onclick="toggleChatPanel();">💬</button>
    <script>
    window.toggleChatPanel = function() {
        // Find and click the hidden Streamlit toggle button
        const toggleBtn = Array.from(document.querySelectorAll('button')).find(
            btn => btn.getAttribute('data-chat-toggle') === 'true'
        );
        if (toggleBtn) {
            toggleBtn.click();
        }
    };
    </script>
    """
    
    st.markdown(fab_html, unsafe_allow_html=True)
    
    # Hidden toggle button for Streamlit state management
    col_hidden = st.columns([1])[0]
    with col_hidden:
        # Store toggle button reference for JavaScript interaction
        toggle_button = st.button(
            "🔘",
            key="fab_toggle",
            help="",
            use_container_width=True
        )
    
    # Hide the toggle button with CSS
    st.markdown(
        """
        <script>
        // Hide the FAB toggle button from view
        document.addEventListener('DOMContentLoaded', function() {
            const buttons = document.querySelectorAll('button');
            for (let btn of buttons) {
                // Find button by checking its text content or data attributes
                if (btn.textContent.includes('🔘')) {
                    btn.style.display = 'none';
                    break;
                }
            }
        });
        
        window.toggleChatPanel = function() {
            // Trigger the hidden button
            const buttons = document.querySelectorAll('button');
            for (let btn of buttons) {
                if (btn.textContent.includes('🔘')) {
                    btn.click();
                    break;
                }
            }
        };
        </script>
        """,
        unsafe_allow_html=True
    )
    
    if toggle_button:
        st.session_state.chat_open = not st.session_state.chat_open
        st.rerun()
    
    # Render chat widget if open - with input form inside the panel
    if st.session_state.chat_open:
        # Build messages HTML
        messages_html = ""
        
        if not st.session_state.chat_history:
            messages_html = '<div class="chat-welcome"><div class="chat-welcome-emoji">🌾</div><div class="chat-welcome-title">नमस्ते Namaste!</div><div class="chat-welcome-text">Ask me anything about farming</div><div class="chat-welcome-text">English • हिंदी • తెలుగు</div></div>'
        else:
            for msg in st.session_state.chat_history:
                msg_class = "user" if msg["role"] == "user" else "assistant"
                msg_icon = "👨‍🌾" if msg["role"] == "user" else "🤖"
                msg_content = msg["content"].replace('<', '&lt;').replace('>', '&gt;')
                messages_html += '<div class="message ' + msg_class + '"><div class="message-bubble">' + msg_icon + ' ' + msg_content + '</div></div>'
        
        # Include input form inside the chat panel HTML
        chat_panel_html = '<div class="chat-widget-container"><div class="chat-header"><h3 class="chat-header-title">💬 Kisaan Mitra</h3><button class="chat-close-btn" onclick="toggleChatPanel();">✕</button></div><div class="chat-messages">' + messages_html + '</div><form class="chat-input-section" id="chat-form" onsubmit="handleChatSubmit(event); return false;"><input type="text" id="chat-input-field" placeholder="Ask about farming, crops, weather..." required /><button type="submit">📤</button></form></div>'
        st.markdown(chat_panel_html, unsafe_allow_html=True)
        
        # Initialize session state for pending message
        if "chat_pending_message" not in st.session_state:
            st.session_state.chat_pending_message = ""
        
        # Create a hidden container for Streamlit message processing
        # This fully hides the input from view using CSS
        with st.container():
            st.markdown("""
            <style>
                /* Hide the chat pending input container */
                .stContainer:has([data-testid="textInput"]) {
                    display: none !important;
                    height: 0 !important;
                    overflow: hidden !important;
                }
            </style>
            """, unsafe_allow_html=True)
            
            # Streamlit requires at least one widget to trigger state updates
            # This hidden input serves as the message receiver from JavaScript
            msg_input = st.text_input(
                label="",
                key="chat_pending_input",
                placeholder="",
            )
            
            # Process any pending message
            if msg_input and msg_input.strip():
                st.session_state.chat_pending_message = msg_input.strip()
                st.session_state.chat_pending_input = ""  # Clear for next message
        
        # JavaScript to handle form submission and communicate with Streamlit
        st.markdown("""
        <script>
        window.chatMessageSent = false;  // Prevent duplicate submissions
        
        window.handleChatSubmit = function(event) {
            event.preventDefault();
            if (window.chatMessageSent) return;  // Prevent double-submit
            
            const input = document.getElementById('chat-input-field');
            const message = input.value.trim();
            
            if (message) {
                window.chatMessageSent = true;
                
                // Find the hidden Streamlit text input with key "chat_pending_input"
                const allInputs = document.querySelectorAll('input[type="text"]');
                let found = false;
                
                for (let i = 0; i < allInputs.length; i++) {
                    const inp = allInputs[i];
                    // Try to find our hidden input (usually near the end)
                    if (i === allInputs.length - 1 || inp.style.display === 'none' || !inp.offsetParent) {
                        try {
                            inp.value = message;
                            inp.dispatchEvent(new Event('input', { bubbles: true }));
                            inp.dispatchEvent(new Event('change', { bubbles: true }));
                            
                            // Trigger Streamlit rerun via hidden buttons or form
                            const hiddenBtn = document.querySelector('button[key="fab_toggle"]');
                            if (hiddenBtn) {
                                setTimeout(() => {
                                    hiddenBtn.click();
                                    setTimeout(() => hiddenBtn.click(), 100);
                                }, 50);
                                found = true;
                                break;
                            }
                        } catch (e) {
                            console.log("Trying next input...");
                        }
                    }
                }
                
                // Clear the form input
                input.value = '';
                window.chatMessageSent = false;
            }
        };
        </script>
        """, unsafe_allow_html=True)
        
        # Process pending message from JavaScript
        if st.session_state.chat_pending_message:
            user_input = st.session_state.chat_pending_message
            print(f"[DEBUG] Chat: Processing message: {user_input}")  # Debug print
            
            is_valid, error_msg = validate_message(user_input)
            print(f"[DEBUG] Chat: Message valid: {is_valid}, error: {error_msg}")  # Debug print
            
            if is_valid:
                # Add user message to history
                user_message = format_chat_message("user", user_input)
                st.session_state.chat_history.append(user_message)
                print(f"[DEBUG] Chat: User message added to history. History length: {len(st.session_state.chat_history)}")  # Debug print
                
                # Clear pending message
                st.session_state.chat_pending_message = ""
                
                try:
                    llm_settings = {
                        "provider": st.session_state.settings.get("provider", "ollama"),
                        "model": st.session_state.settings.get("model", "llama3.2:1b"),
                        "api_key": st.session_state.settings.get("api_key", "")
                    }
                    
                    print(f"[DEBUG] Chat: LLM Settings: provider={llm_settings['provider']}, model={llm_settings['model']}")  # Debug print
                    
                    with st.spinner("🤔 Kisaan Mitra is thinking..."):
                        response = get_chatbot_response(
                            user_message=user_input,
                            chat_history=st.session_state.chat_history[:-1],  # Exclude user message we just added
                            settings=llm_settings
                        )
                    
                    print(f"[DEBUG] Chat: Response received: {response[:100] if response else 'None'}...")  # Debug print
                    
                    assistant_message = format_chat_message("assistant", response)
                    st.session_state.chat_history.append(assistant_message)
                    print(f"[DEBUG] Chat: History length after response: {len(st.session_state.chat_history)}")  # Debug print
                    st.rerun()
                    
                except Exception as e:
                    print(f"[DEBUG] Chat: Exception occurred: {str(e)}")  # Debug print
                    error_response = f"❌ {str(e)}"
                    error_msg_obj = format_chat_message("assistant", error_response)
                    st.session_state.chat_history.append(error_msg_obj)
                    st.rerun()
            else:
                st.session_state.chat_pending_message = ""  # Clear invalid message

# Render floating widget
render_floating_widget()

# Footer
st.markdown("---")
st.markdown(
    """
    <div style='text-align: center; color: #666; padding: 1rem;'>
        <p>🌾 Kisaan Mitra - Empowering Farmers with AI 🌾</p>
        <p style='font-size: 0.8rem;'>Built with ❤️ for Indian Farmers</p>
    </div>
    """,
    unsafe_allow_html=True
)